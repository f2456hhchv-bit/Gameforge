{
  "name": "gameforge",
  "version": "1.0.0",
  "description": "GameForge Studio - browser-based game design & development studio (static, IndexedDB-backed, no server required)",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./css/input.css -o ./css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/tailwind.css --watch",
    "serve": "python3 -m http.server 8080",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "build:standalone": "node scripts/build-standalone.mjs"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:41729/git/f2456hhchv-bit/Gameforge"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^3.4.19"
  }
}
